# =============================================================================
# SubI — copy to `.env.local` (never commit real secrets)
# =============================================================================
# Notes:
# - `NEXT_PUBLIC_*` are embedded in the client bundle.
# - `TOKEN_ENCRYPTION_KEY` must decode from base64 to exactly 32 bytes (openssl rand -base64 32).
# - “Subscriptions” in the app = tracked services (Netflix, etc.). “SubI Pro” / Paystack = billing for
#   your SubI account (mailboxes, reminder tiers). Plan env vars below are for that billing only.

# -----------------------------------------------------------------------------
# Supabase (Project Settings → API)
# -----------------------------------------------------------------------------
# Auth: enable Google / Apple / Email in Supabase. Redirect URLs must include
# `${ORIGIN}/auth/callback` (use your local dev or production origin).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service role: server routes only (`api/billing/webhooks/paystack`, `api/account/delete`). Never ship to clients.
SUPABASE_SERVICE_ROLE_KEY=

# -----------------------------------------------------------------------------
# SubI Pro billing — Paystack (server-only)
# -----------------------------------------------------------------------------
# Secret key: Paystack Dashboard → Settings → API Keys & Webhooks → Secret key.
# Do not prefix with NEXT_PUBLIC (must never ship to the browser).
PAYSTACK_SECRET_KEY=

# Plan codes (each value is Paystack’s `plan_code`, e.g. PLN_xxxxxxxxxx).
# Create one Plan per SKU in Paystack Dashboard → Plans (currency + interval must match).
# Used by POST /api/billing/pro-checkout with transaction/initialize + `plan`.
# Each plan’s amount/currency in Paystack must match `pricing_quotes` (migration seed) or Paystack may reject charges.
PAYSTACK_SUBI_PRO_PLAN_NGN_MONTHLY=
PAYSTACK_SUBI_PRO_PLAN_NGN_ANNUALLY=
PAYSTACK_SUBI_PRO_PLAN_USD_MONTHLY=
PAYSTACK_SUBI_PRO_PLAN_USD_ANNUALLY=

# Webhook URL (HTTPS): `{ORIGIN}/api/billing/webhooks/paystack` — Dashboard → Settings → API Keys & Webhooks.
# Signing uses the same `PAYSTACK_SECRET_KEY`; body must be verified as raw UTF-8 (see route handler).

# -----------------------------------------------------------------------------
# Gmail sync (Google Cloud OAuth 2.0 — Web application)
# -----------------------------------------------------------------------------
# Must match an Authorized redirect URI in Google Cloud: `<origin>/api/gmail/callback`.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=

# -----------------------------------------------------------------------------
# Token encryption (server-only; Gmail refresh tokens at rest)
# -----------------------------------------------------------------------------
TOKEN_ENCRYPTION_KEY=

# -----------------------------------------------------------------------------
# Email — Resend (optional for Next.js; Edge `reminder-dispatch` uses Supabase secrets)
# -----------------------------------------------------------------------------
RESEND_API_KEY=
RESEND_FROM=

# -----------------------------------------------------------------------------
# Supabase Edge function `reminder-dispatch` (Dashboard → Edge Functions → Secrets)
# -----------------------------------------------------------------------------
# CRON_SECRET=
# RESEND_API_KEY=
# RESEND_FROM=
